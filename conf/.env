# Materialious application configuration
# This file is generated by the YunoHost app scripts from the app settings.
# The two "Accounts" values below can also be flipped from the app's Config Panel
# in the YunoHost webadmin (which regenerates this file and restarts the service).

# --- Secrets / storage ---
# COOKIE_SECRET is persisted in the app settings (restored on backup/restore).
COOKIE_SECRET=__COOKIE_SECRET__
# SQLite database file, stored in the app's writable data directory (backed up as a file).
DATABASE_CONNECTION_URI=sqlite://__DATA_DIR__/materialious.db

# --- Backend / auth mode (do not change; the package is built for this mode) ---
PUBLIC_BUILD_WITH_BACKEND=true
PUBLIC_INTERNAL_AUTH=true
PUBLIC_REQUIRE_AUTH=true
PUBLIC_CAPTCHA_DISABLED=false

# --- Accounts (togglable via Config Panel) ---
# Turn registration on to create your account(s), then turn it back off.
PUBLIC_REGISTRATION_ALLOWED=__REGISTRATION_ALLOWED__
# Comma-separated app usernames granted admin privileges, e.g. "alice,bob".
PUBLIC_ADMIN_USERNAMES=__ADMIN_USERNAMES__
